# Font and Layout (Unchanged as requested)
font_family         JetBrainsMono Nerd Font
bold_font           auto
italic_font         auto
bold_italic_font    auto
font_size           12.0

background_opacity    0.9

# Cursor (Unchanged as requested)
cursor_blink_interval 0.5
shell_integration   no-cursor

# --- Grayscale Palette (Modified) ---
# Core Colors
foreground            #8c8c8c
background            #000000
cursor                #ffffff
cursor_text_color     background

selection_background  #ffffff
color0                #8c8c8c
color8                #8c8c8c
color1                #ff0000
color9                #8c8c8c
color2                #ffffff
color10               #8c8c8c
color3                #8c8c8c
color11               #8c8c8c
color4                #ffffff
color12               #8c8c8c
color5                #8c8c8c
color13               #8c8c8c
color6                #8c8c8c
color14               #8c8c8c
color7                #8c8c8c
color15               #8c8c8c
selection_foreground #000000

confirm_os_window_close 0
allow_remote_control yes
dynamic_background_opacity yes

